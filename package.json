{
  "name": "innolab-cms-portal",
  "version": "1.0.0",
  "private": true,
  "description": "Copyright-safe portfolio CMS portal with an Angular frontend and Strapi/Node.js backend.",
  "homepage": "https://github.com/A7med-Sghaier/innolab-cms-portal",
  "repository": {
    "type": "git",
    "url": "https://github.com/A7med-Sghaier/innolab-cms-portal.git"
  },
  "scripts": {
    "install:front": "npm --prefix innolab-front install",
    "install:server": "npm --prefix innolab-server install",
    "install:all": "npm run install:server && npm run install:front",
    "start:front": "npm --prefix innolab-front start",
    "start:server": "npm --prefix innolab-server start",
    "build:front": "npm --prefix innolab-front run build",
    "lint:front": "npm --prefix innolab-front run lint",
    "lint:server": "npm --prefix innolab-server run lint",
    "docker:up": "sh scripts/start-docker.sh up",
    "docker:down": "sh scripts/start-docker.sh down",
    "docker:logs": "sh scripts/start-docker.sh logs",
    "docker:clean": "sh scripts/start-docker.sh clean"
  },
  "engines": {
    "node": "10.x",
    "npm": "6.x"
  }
}
